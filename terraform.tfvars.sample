# Variáveis do provedor
regiao = "us-east-1"
perfil = "terraform"

# Identificação do projeto
project_name = "eks-dev"

# Rede (mantendo 3 AZs / 3 subnets públicas e 3 privadas)
vpc_cidr = "10.10.0.0/16"

public_subnets_cidrs  = ["10.10.1.0/24", "10.10.2.0/24", "10.10.3.0/24"]
private_subnets_cidrs = ["10.10.11.0/24", "10.10.12.0/24", "10.10.13.0/24"]

# EKS
eks_cluster_version = "1.34"

# Nodes
node_instance_type = "t3.medium"
desired_capacity   = 3
min_size           = 3
max_size           = 6